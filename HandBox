'''
1 摄像头显示画面
2 加载手势mediapipe

'''
import cv2 as cv
import mediapipe as mp # 模块导入 
import math
mp_drawing = mp.solutions.drawing_utils #绘制
mp_drawing_styles = mp.solutions.drawing_styles #绘制样式 
mp_hands = mp.solutions.hands # 手点位识别



cap = cv.VideoCapture(0)


boxX = 100
boxY = 100
bSize = 100
L1 = 0
L2 = 0
is_activate = False
CCcolor = (0,200,0)
# 1 读取画面的宽高 
width = cap.get(cv.CAP_PROP_FRAME_WIDTH)
height = cap.get(cv.CAP_PROP_FRAME_HEIGHT)

hands = mp_hands.Hands(
    model_complexity=0,
    max_num_hands = 1,
    min_detection_confidence=0.5,
    min_tracking_confidence=0.5)

while True:
    res,image= cap.read()

    if not res:
        print("摄像头打开失败")
        break
    # To improve performance, optionally mark the image as not writeable to
    # pass by reference.
    image.flags.writeable = False #关闭图片上面绘制点
    image = cv.cvtColor(image, cv.COLOR_BGR2RGB) # BGR2RGB
    results = hands.process(image) #每一张图片都给hands去处理 

    # Draw the hand annotations on the image.
    image.flags.writeable = True #开启图片上面绘制点 
    image = cv.cvtColor(image, cv.COLOR_RGB2BGR) #RGB2BGR
    if results.multi_hand_landmarks: #如果检测到多张手
      for hand_landmarks in results.multi_hand_landmarks: #遍历多张手 
        # draw_landmarks(图片,绘制手的21个点位,手连成线,点位的样式,颜色)
        mp_drawing.draw_landmarks(
            image,
            hand_landmarks,
            mp_hands.HAND_CONNECTIONS,
            mp_drawing_styles.get_default_hand_landmarks_style(),
            mp_drawing_styles.get_default_hand_connections_style())

        # 2 获取食指 5 大拇指 
        # print(hand_landmarks.landmark[8])
        indexX,indexY = int(hand_landmarks.landmark[8].x*width) ,int(hand_landmarks.landmark[8].y*height)
        thumbX,thumbY = int(hand_landmarks.landmark[4].x*width) ,int(hand_landmarks.landmark[4].y*height)
        dis = math.hypot((indexX-thumbX),(indexY-thumbY))
        # 6 判断两手指捏合 
        # print(dis)
        if dis <30:
            # print(indexX,indexY)
            # cv.circle(image,(indexX,indexY),20,(0,0,200),-1)
            # 3 判断手指在不在画面中 
            if (indexX>boxX) and (indexX<boxX+bSize) and (indexY>boxY) and (indexY<boxY+bSize):
                if is_activate==False:
                    is_activate = True
                    print("在")
                    L1 = abs(indexX-boxX)
                    L2 = abs(indexY-boxY)
            else:
            #    print("不在") 
                pass
            # 4 方块跟随
            if is_activate:
                boxX = int(indexX-L1)
                boxY = int(indexY-L2)
                CCcolor = (0,200,200)
        else:
            is_activate=False
            CCcolor = (0,200,0)
    overlay = image.copy() #添加一层 
    cv.rectangle(image,(boxX,boxY),(boxX+bSize,boxY+bSize),CCcolor,-1) #实心
    image = cv.addWeighted(overlay,0.5,image,0.5,0) #添加的这一层有透明度 
    image = cv.flip(image,1)
    cv.imshow("win",image)

    code = cv.waitKey(1) & 0xFF
    if code ==27 or code==23:
        print("程序退出")
        break

cap.release()
cv.destroyAllWindows()
